vars: {
  d2-config: {
    layout-engine: elk
  }
}

direction: down

root: "Root\n| 300 | 700 |"

int1: "Internal\n| 100 | 200 |\n"
int2: "Internal\n| 400 | 600 |\n"
int3: "Internal\n| 800 | 900 |\n"

leaf1: "Leaf\n| 50 | 80 |"
leaf2: "Leaf\n| 110 | 160 |"
leaf3: "Leaf\n| 210 | 260 |"
leaf4: "Leaf\n| 310 | 380 |"
leaf5: "Leaf\n| 410 | 560 |"
leaf6: "Leaf\n| 610 | 680 |"
leaf7: "Leaf\n| 710 | 780 |"
leaf8: "Leaf\n| 810 | 880 |"
leaf9: "Leaf\n| 910 | 980 |"

row1: "rows"
row2: "rows"
row3: "rows"
row4: "rows"
row5: "rows"
row6: "rows"
row7: "rows"
row8: "rows"
row9: "rows"

spine: {
  label: "← sequential scan →"
  shape: rectangle
  style: {
    stroke-dash: 4
    font-size: 12
    italic: true
  }
}

root -> int1
root -> int2
root -> int3

int1 -> leaf1
int1 -> leaf2
int1 -> leaf3

int2 -> leaf4
int2 -> leaf5
int2 -> leaf6

int3 -> leaf7
int3 -> leaf8
int3 -> leaf9

leaf1 -> row1
leaf2 -> row2
leaf3 -> row3
leaf4 -> row4
leaf5 -> row5
leaf6 -> row6
leaf7 -> row7
leaf8 -> row8
leaf9 -> row9

row1 -> spine: {
  style: {
    stroke: "transparent"
    stroke-width: 0
  }
}

row9 -> spine: {
  style: {
    stroke: "transparent"
    stroke-width: 0
  }
}
